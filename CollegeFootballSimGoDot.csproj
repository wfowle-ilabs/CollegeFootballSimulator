<Project Sdk="Godot.NET.Sdk/4.6.3">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>CollegeFootballSimGoDot</RootNamespace>
    <!-- Only the Godot-side scripts live here; core logic is a referenced library.
         Disable the default **/*.cs glob so this project doesn't swallow src/ and tests/. -->
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="src/Game/**/*.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="src/CfbSim.Core/CfbSim.Core.csproj" />
  </ItemGroup>

</Project>
